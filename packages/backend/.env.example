# MongoDB
MONGODB_URI=mongodb://localhost:27017/campuspool

# JWT
JWT_ACCESS_SECRET=your-random-access-secret-64-char
JWT_REFRESH_SECRET=your-random-refresh-secret-64-char
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Server
PORT=5000
FRONTEND_URL=http://localhost:5173
NODE_ENV=development

# Default values for notifications / fallbacks
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password

TWILIO_ACCOUNT_SID=ACxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Admin Config
PLATFORM_ADMIN_EMAIL=admin@campuspool.in
PLATFORM_ADMIN_PASSWORD=admin
